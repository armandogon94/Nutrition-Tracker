# ============================================
# FitTracker - Environment Configuration
# ============================================
# Copy to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fit_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fit_db

# --- Open Food Facts (no key needed) ---
OFF_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=FitTracker/2.0 (fit.armandointeligencia.com)

# --- USDA FoodData Central ---
# Free API key: https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_KEY=your_usda_api_key_here

# --- FatSecret Platform API ---
# Register: https://platform.fatsecret.com/platform-api
# Uses OAuth 1.0a authentication (2-legged, no user tokens needed)
FATSECRET_CONSUMER_KEY=your_consumer_key_here
FATSECRET_CONSUMER_SECRET=your_consumer_secret_here

# --- Claude Vision API (photo food recognition) ---
# Get key: https://console.anthropic.com/
# Used for photo-based food identification (Sonnet model)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Application ---
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
BACKEND_PORT=8030
FRONTEND_PORT=3030

# --- Frontend (public, exposed to browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8030
