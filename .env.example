# ============================================
# Nutrition Tracker - Environment Configuration
# ============================================
# Copy to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nutrition_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nutrition_db

# --- Open Food Facts (no key needed) ---
OFF_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=NutritionTracker/1.0 (nutrition.armandointeligencia.com)

# --- USDA FoodData Central ---
# Free API key: https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_KEY=your_usda_api_key_here

# --- FatSecret Platform API ---
# Register: https://platform.fatsecret.com/platform-api
# Uses OAuth 1.0a authentication
FATSECRET_CONSUMER_KEY=your_consumer_key_here
FATSECRET_CONSUMER_SECRET=your_consumer_secret_here

# --- Application ---
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
BACKEND_PORT=8001
FRONTEND_PORT=3000

# --- Frontend (public, exposed to browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8001
